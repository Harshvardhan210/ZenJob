# Root .gitignore for MagicCounter / JobCollector

# Backend exclusions
backend/.env
backend/.venv/
backend/jobs.db
backend/uploads/
backend/__pycache__/
backend/app/__pycache__/
*.pyc

# Frontend exclusions
frontend/node_modules/
frontend/dist/
frontend/dist-ssr/
frontend/*.local

# Logs and system files
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.DS_Store
Thumbs.db

# IDEs/Editors
.vscode/
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
